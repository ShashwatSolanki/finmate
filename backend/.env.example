# Copy to .env and adjust. Used by FastAPI + SQLAlchemy.
# Special characters in the password must be URL-encoded in the URL (@ -> %40, # -> %23, etc.).
DATABASE_URL=postgresql+psycopg2://finmate:finmate@localhost:5432/finmate

# JWT signing — use a long random secret in production (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32

# Optional: Alpha Vantage (Investment agent extras)
# ALPHA_VANTAGE_API_KEY=

# Local FinMate LLM (Qwen + LoRA in app/ml/). Requires adapter_model.safetensors in FINMATE_LORA_PATH or a checkpoint-* subfolder.
# FINMATE_USE_LLM=false
# FINMATE_LORA_PATH=app/ml/finmate-lora
# FINMATE_MAX_NEW_TOKENS=256
